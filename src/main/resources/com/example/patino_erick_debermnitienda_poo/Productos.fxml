<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.patino_erick_debermnitienda_poo.ProductoController"
      styleClass="productos-root"
      spacing="16">

    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- Breadcrumb -->
    <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="breadcrumb">
        <Label text="Inicio" styleClass="breadcrumb-link"/>
        <Label text="/" styleClass="breadcrumb-sep"/>
        <Label text="Productos" styleClass="breadcrumb-current"/>
    </HBox>

    <!-- ===== FORMULARIO ===== -->
    <VBox styleClass="card" spacing="16">

        <!-- Título sección -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="section-bar"/>
            <Label text="Registro / Edición de Producto" styleClass="section-title"/>
        </HBox>

        <!-- Fila 1: Código | Nombre | Categoría -->
        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0" spacing="6">
                <Label styleClass="input-label" text="Código del producto"/>
                <TextField fx:id="txtCodigo" styleClass="input-field" promptText="Ej: P001"/>
            </VBox>
            <VBox GridPane.columnIndex="1" spacing="6">
                <Label styleClass="input-label" text="Nombre del producto"/>
                <TextField fx:id="txtNombre" styleClass="input-field" promptText="Ingrese el nombre"/>
            </VBox>
            <VBox GridPane.columnIndex="2" spacing="6">
                <Label styleClass="input-label" text="Categoría"/>
                <ComboBox fx:id="cmbCategoria" styleClass="input-combo" maxWidth="Infinity"/>
            </VBox>
        </GridPane>

        <!-- Fila 2: Precio | Stock | Estado -->
        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="35"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0" spacing="6">
                <Label styleClass="input-label" text="Precio"/>
                <HBox styleClass="price-box" alignment="CENTER_LEFT" spacing="0">
                    <Label styleClass="price-prefix" text="#"/>
                    <TextField fx:id="txtPrecio" styleClass="input-field-price" promptText="0.00" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            <VBox GridPane.columnIndex="1" spacing="6">
                <Label styleClass="input-label" text="Stock"/>
                <TextField fx:id="txtStock" styleClass="input-field" promptText="0"/>
            </VBox>
            <VBox GridPane.columnIndex="2" spacing="6">
                <Label styleClass="input-label" text="Estado"/>
                <ComboBox fx:id="cmbEstado" styleClass="input-combo" maxWidth="Infinity"/>
            </VBox>
        </GridPane>

        <!-- Botones CRUD -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="+ Nuevo"      styleClass="btn-nuevo"     onAction="#handleNuevo"/>
            <Button text="💾 Guardar"   styleClass="btn-guardar"   onAction="#handleGuardar"/>
            <Button text="✏ Actualizar" styleClass="btn-actualizar" onAction="#handleActualizar"/>
            <Button text="🗑 Eliminar"  styleClass="btn-eliminar"  onAction="#handleEliminar"/>
            <Button text="↺ Limpiar"   styleClass="btn-limpiar"   onAction="#handleLimpiar"/>
        </HBox>

        <!-- Mensaje retroalimentación -->
        <Label fx:id="lblMensaje" styleClass="msg-label" wrapText="true"/>

    </VBox>

    <!-- ===== TABLA ===== -->
    <VBox styleClass="card" spacing="12" >

        <!-- Encabezado tabla -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="section-bar"/>
            <Label text="Lista de Productos" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="search-box" alignment="CENTER_LEFT" spacing="6">
                <Label text="🔍" styleClass="search-icon"/>
                <TextField fx:id="txtBuscar" styleClass="search-field" promptText="Buscar producto..."/>
            </HBox>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="tablaProductos" prefHeight="250" maxHeight="250" styleClass="tabla-productos">
            <columns>
                <TableColumn fx:id="colCodigo"    text="Código"    prefWidth="90"  minWidth="70"/>
                <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="200" minWidth="120"/>
                <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120" minWidth="90"/>
                <TableColumn fx:id="colPrecio"    text="Precio"    prefWidth="90"  minWidth="70"/>
                <TableColumn fx:id="colStock"     text="Stock"     prefWidth="80"  minWidth="60"/>
                <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="100" minWidth="80"/>
                <TableColumn fx:id="colAcciones"  text="Acciones"  prefWidth="100" minWidth="90"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

    </VBox>

    <!-- Footer -->
    <Label styleClass="footer-label" text="© 2024 MiTienda - Sistema de Ventas. Todos los derechos reservados." alignment="CENTER">
        <VBox.margin><Insets top="4"/></VBox.margin>
    </Label>

</VBox>
